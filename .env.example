# Gabru-Agent environment variables
# Copy this file to .env and fill in the values you need.

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: override the default model (defaults to a TODO value in config)
# GABRU_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# Optional: override the Gabru home directory (default: ~/.gabru)
# GABRU_HOME=

# Optional: log verbosity (DEBUG, INFO, WARNING, ERROR). Default: INFO
# GABRU_LOG_LEVEL=INFO
